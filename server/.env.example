PORT=3001
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/buddylockin
GEMINI_API_KEY=
ELEVENLABS_API_KEY=
# Single narrator voice ("Professor Oak" style) — used for quiz questions, recaps, alerts
ELEVENLABS_VOICE_ID=
SOLANA_RPC_URL=https://api.devnet.solana.com
# Server-controlled escrow wallet — fund this on devnet before the demo
# Generate: solana-keygen new --outfile server-wallet.json
# Paste the key array from server-wallet.json here
SERVER_WALLET_KEYPAIR=[]
SESSION_SECRET=changeme
JWT_SECRET=changeme-use-a-long-random-string-in-production
